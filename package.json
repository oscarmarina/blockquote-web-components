{
  "name": "blockquote-web-components",
  "version": "2.19.0",
  "private": true,
  "description": "Monorepo - Blockquote Web Components",
  "homepage": "https://github.com/oscarmarina/blockquote-web-components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oscarmarina/blockquote-web-components"
  },
  "author": {
    "name": "oscarmarina",
    "url": "https://62d3439a0eebee66a69d4650--adorable-macaron-7c1b61.netlify.app"
  },
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/**/*"
    ]
  },
  "scripts": {
    "analyze": "lerna run analyze --stream --concurrency 1",
    "clean": "rm package-lock.json && lerna clean",
    "clean:packages": "lerna exec -- rm -rf ./node_modules && npm run clean:packages:dev && npm run clean:packages:coverage",
    "clean:packages:coverage": "lerna exec -- rm -rf ./test/coverage",
    "clean:packages:dev": "lerna exec -- rm -rf ./dev && lerna exec -- rm -rf ./package-lock.json",
    "eslint": "eslint --fix 'packages/**/*.*'",
    "format": "lerna run format --stream --concurrency 1",
    "lint": "npm run eslint && npm run prettier && npm run stylelint",
    "prepare": "husky",
    "prettier": "prettier --write --ignore-path .prettierignore 'packages/**/*.{js,ts,css,scss,html,json}'",
    "push": "git push --follow-tags origin main",
    "release": " npm ci && npm run test:pre-push && lerna version --no-push",
    "site": "npm run site:prepare && npm run site:copy",
    "site:copy": "rm -rf ./site/**/* && node scripts/move-dev-directory.js",
    "site:prepare": "npm run clean:packages:dev && lerna run dev:vite",
    "standard": "commit-and-tag-version",
    "stylelint": "stylelint -f verbose --ignore-path .prettierignore 'packages/**/*.{js,ts,css,scss,html}'",
    "test": "lerna run test --stream --concurrency 1 -- --run",
    "test:pre-push": "lerna run test --stream --concurrency 1 --since origin/main -- --run",
    "test:scope": "func() { lerna run test --stream --concurrency 1 --scope @blockquote-web-components/${1}; }; func",
    "postversion": "npm run standard"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional",
      "@commitlint/config-workspace-scopes"
    ],
    "rules": {
      "header-max-length": [
        2,
        "always",
        150
      ]
    }
  },
  "prettier": {
    "bracketSameLine": true,
    "bracketSpacing": false,
    "htmlWhitespaceSensitivity": "ignore",
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "es5",
    "overrides": [
      {
        "files": "*.{scss,css}",
        "options": {
          "singleQuote": false
        }
      },
      {
        "files": "*.json",
        "options": {
          "parser": "json-stringify"
        }
      }
    ]
  },
  "stylelint": {
    "extends": "stylelint-config-standard-scss",
    "allowEmptyInput": true,
    "rules": {
      "custom-property-pattern": null,
      "no-duplicate-selectors": null,
      "color-function-notation": null,
      "alpha-value-notation": null,
      "media-feature-name-no-unknown": null,
      "comment-empty-line-before": null,
      "declaration-empty-line-before": null,
      "property-no-vendor-prefix": null,
      "selector-attribute-quotes": null,
      "value-no-vendor-prefix": null
    },
    "overrides": [
      {
        "files": [
          "**/*.html"
        ],
        "customSyntax": "postcss-html"
      },
      {
        "files": [
          "**/*.{ts,js}"
        ],
        "customSyntax": "postcss-lit"
      }
    ]
  },
  "overrides": {
    "@npmcli/move-file": "npm:@npmcli/fs@latest",
    "are-we-there-yet": "npm:noop2@latest",
    "gauge": "npm:noop2@latest",
    "glob": "^13.0.6",
    "inflight": "npm:noop2@latest",
    "keygrip": "npm:noop2@latest",
    "npmlog": "npm:noop2@latest",
    "read-package-json": "npm:@npmcli/package-json@latest",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/eslint-plugin": "^7.27.1",
    "@blockquote/cem-to-markdown-readme": "^1.0.0",
    "@blockquote/coverage-table-reporter": "^1.2.0",
    "@blockquote/rollup-plugin-total-bundlesize": "^2.3.1",
    "@blockquote/sass-style-template": "^5.1.0",
    "@blockquote/vite-plugin-prevent-rewrite-imports-type-module": "^0.1.1",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/config-workspace-scopes": "^20.4.3",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.58.1",
    "@html-eslint/parser": "^0.58.1",
    "@open-wc/semantic-dom-diff": "^0.20.1",
    "@open-wc/testing-helpers": "^3.0.1",
    "@rollup/plugin-multi-entry": "^7.1.0",
    "@types/mocha": "^10.0.10",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "chai-a11y-axe": "^1.5.0",
    "commit-and-tag-version": "^12.6.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "nise": "^6.1.3",
    "nx": "^22.5.4",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postcss-html": "1.8.1",
    "postcss-lit": "1.4.1",
    "prettier": "^3.8.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-node-externals": "^8.1.2",
    "sort-package-json": "^3.6.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tinyglobby": "^0.2.15",
    "ts-lit-plugin": "^2.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "lit-html": "^3.3.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "commit-and-tag-version": {
    "releaseCommitMessageFormat": "chore: release {{currentTag}}",
    "commitUrlFormat": "{{host}}/oscarmarina/blockquote-web-components/commit/{{hash}}",
    "compareUrlFormat": "{{host}}/oscarmarina/blockquote-web-components/compare/{{previousTag}}...{{currentTag}}"
  }
}
